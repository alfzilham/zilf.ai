# ============================================================
# Hams.ai — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Providers ---

# Groq (fast cloud inference)
GROQ_API_KEY=gsk_...

# Google Gemini (Google AI Studio)
GOOGLE_API_KEY=AIzaSy...

# Ollama (no key needed — runs locally)
OLLAMA_BASE_URL=http://localhost:11434

# --- Ollama Available Models ---
# llama3:latest         (4.7 GB)
# mistral:latest        (4.4 GB)
# codellama:latest      (3.8 GB)
# deepseek-coder:latest (776 MB) ← recommended for coding tasks

# --- Tool: Web Search ---
TAVILY_API_KEY=tvly-...

# --- Agent Behaviour ---

# Default LLM provider: groq | google | ollama
AGENT_LLM_PROVIDER=ollama

# Groq options   : llama3-70b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
# Gemini options : gemini-1.5-flash | gemini-1.5-pro
# Ollama options : llama3 | mistral | codellama | deepseek-coder
AGENT_MODEL=deepseek-coder

AGENT_MAX_STEPS=30
AGENT_TOOL_TIMEOUT=30

# --- Sandbox ---
SANDBOX_IMAGE=hams-ai-sandbox:latest
SANDBOX_CPU_LIMIT=1.0
SANDBOX_MEMORY_LIMIT=512m

# --- Observability (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO